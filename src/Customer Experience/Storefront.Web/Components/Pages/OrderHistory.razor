@page "/orders"

<PageTitle>Order History - CritterSupply</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">Order History</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
    Track your past orders and shipment status
</MudText>

<MudPaper Class="pa-8 d-flex flex-column align-center" Elevation="0" Style="border: 1px dashed rgba(0,0,0,0.12); border-radius: 12px;">
    <MudIcon Icon="@Icons.Material.Filled.Receipt" Color="Color.Secondary" Style="font-size: 4rem;" Class="mb-4" />
    <MudText Typo="Typo.h6" Align="Align.Center" Class="mb-2">No orders yet</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" Class="mb-6">
        Your order history will appear here once you've placed an order.
    </MudText>
    <MudButton Variant="Variant.Filled"
               Color="Color.Primary"
               Href="/products"
               StartIcon="@Icons.Material.Filled.Storefront">
        Start Shopping
    </MudButton>
</MudPaper>

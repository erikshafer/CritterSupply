@page "/not-found"
@layout MainLayout

<PageTitle>Page Not Found - CritterSupply</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-12 text-center">
    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Secondary" Style="font-size: 5rem; width: 5rem; height: 5rem;" Class="mb-4" />
    <MudText Typo="Typo.h4" Class="mb-2">Page Not Found</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6">
        Sorry, we couldn't find the page you're looking for. It may have moved or no longer exists.
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.Home">
        Back to Home
    </MudButton>
    <MudButton Variant="Variant.Outlined" Color="Color.Primary" Href="/products" StartIcon="@Icons.Material.Filled.Storefront" Class="ml-2">
        Browse Products
    </MudButton>
</MudContainer>
@page "/cart"
@attribute [Authorize]
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IConfiguration Configuration
@implements IAsyncDisposable

<PageTitle>Shopping Cart - CritterSupply</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Shopping Cart</MudText>

@if (_isLoading)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText Typo="Typo.body1" Class="mt-2">Loading your cart...</MudText>
}
else if (_cartView == null || !_cartView.Items.Any())
{
    <MudAlert Severity="Severity.Info">Your cart is empty.</MudAlert>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/products" Class="mt-4">
        Browse Products
    </MudButton>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudPaper Class="pa-4">
                @foreach (var item in _cartView.Items)
                {
                    <MudCard Class="mb-3">
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="3">
                                    @if (string.IsNullOrEmpty(item.ProductImageUrl))
                                    {
                                        <div class="d-flex align-center justify-center" role="img" aria-label="Product image not available" style="width: 100%; height: 100px; background: #f5f5f5; border-radius: 4px;">
                                            <MudIcon Icon="@Icons.Material.Filled.Pets" Color="Color.Secondary" />
                                        </div>
                                    }
                                    else
                                    {
                                        <MudImage Src="@item.ProductImageUrl" Alt="@item.ProductName" Height="100" ObjectFit="ObjectFit.Cover" />
                                    }
                                </MudItem>
                                <MudItem xs="6">
                                    <MudText Typo="Typo.h6">@item.ProductName</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">SKU: @item.Sku</MudText>
                                    <MudText Typo="Typo.body1" Class="mt-2">@item.UnitPrice.ToString("C")</MudText>
                                </MudItem>
                                <MudItem xs="3" Class="d-flex flex-column align-end">
                                    <div class="d-flex align-center mb-2">
                                        <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                                       Size="Size.Small"
                                                       OnClick="@(() => DecreaseQuantity(item.Sku, item.Quantity))"
                                                       Disabled="@(item.Quantity <= 1 || _isProcessing)" />
                                        <MudText Typo="Typo.body1" Class="mx-2">@item.Quantity</MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                                       Size="Size.Small"
                                                       OnClick="@(() => IncreaseQuantity(item.Sku, item.Quantity))"
                                                       Disabled="@_isProcessing" />
                                    </div>
                                    <MudText Typo="Typo.h6" Class="mb-2">@item.LineTotal.ToString("C")</MudText>
                                    <MudButton Variant="Variant.Text"
                                               Color="Color.Error"
                                               Size="Size.Small"
                                               StartIcon="@Icons.Material.Filled.Delete"
                                               OnClick="@(() => RemoveItem(item.Sku))"
                                               Disabled="@_isProcessing">
                                        Remove
                                    </MudButton>
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                }
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h5" Class="mb-4">Order Summary</MudText>
                <MudDivider Class="mb-3" />
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body1">Subtotal</MudText>
                    <MudText Typo="Typo.body1">@_cartView.Subtotal.ToString("C")</MudText>
                </div>
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Shipping</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">From $5.99</MudText>
                </div>
                <MudDivider Class="my-3" />
                <div class="d-flex justify-space-between mb-4">
                    <MudText Typo="Typo.h6">Total</MudText>
                    <MudText Typo="Typo.h6">@_cartView.Subtotal.ToString("C")</MudText>
                </div>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           OnClick="@ProceedToCheckout"
                           Disabled="@_isProcessing">
                    @if (_isProcessing)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Proceeding...</span>
                    }
                    else
                    {
                        <span>Proceed to Checkout</span>
                    }
                </MudButton>
            </MudPaper>

            @if (_sseConnected)
            {
                <MudChip T="string" Icon="@Icons.Material.Filled.Wifi" Color="Color.Success" Size="Size.Small" Class="mt-2">
                    Real-time updates active
                </MudChip>
            }
        </MudItem>
    </MudGrid>
}

@code {
    private CartView? _cartView;
    private bool _isLoading = true;
    private bool _isProcessing = false;
    private bool _sseConnected = false;
    private DotNetObjectReference<Cart>? _dotNetHelper;
    private Guid _customerId;
    private Guid? _cartId;
    private bool _hasRendered = false;

    protected override async Task OnInitializedAsync()
    {
        // Get authenticated customer ID
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var customerIdClaim = authState.User.FindFirst("CustomerId")?.Value;
        if (!Guid.TryParse(customerIdClaim, out _customerId))
        {
            // Should not happen due to [Authorize] but handle gracefully
            return;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_hasRendered)
        {
            _hasRendered = true;

            // Get cart ID from localStorage (must be after render for JS interop)
            var cartIdString = await JS.InvokeAsync<string?>("authHelper.getCartId");
            if (!string.IsNullOrEmpty(cartIdString) && Guid.TryParse(cartIdString, out var cartId))
            {
                _cartId = cartId;
            }

            await LoadCart();

            if (_customerId != Guid.Empty)
            {
                await SubscribeToSSE();
            }

            StateHasChanged(); // Trigger re-render with cart data
        }
    }

    private async Task LoadCart()
    {
        _isLoading = true;
        try
        {
            if (!_cartId.HasValue)
            {
                // No cart yet - show empty
                _cartView = null;
                return;
            }

            var client = HttpClientFactory.CreateClient("StorefrontApi");
            // Query BFF to get cart by cartId
            var response = await client.GetFromJsonAsync<CartView>($"/api/storefront/carts/{_cartId.Value}");
            _cartView = response;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            Console.WriteLine("Cart not found - clearing localStorage");
            await JS.InvokeVoidAsync("authHelper.clearCartId");
            _cartView = null;
            _cartId = null;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load cart: {ex.Message}");
            _cartView = null;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SubscribeToSSE()
    {
        try
        {
            _dotNetHelper = DotNetObjectReference.Create(this);
            var apiBaseUrl = Configuration["ApiClients:StorefrontApiUrl"] ?? "http://localhost:5237";
            var hubUrl = $"{apiBaseUrl}/hub/storefront";
            await JS.InvokeVoidAsync("signalrClient.subscribe", _customerId.ToString(), _dotNetHelper, hubUrl);
            _sseConnected = true;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to subscribe to SignalR: {ex.Message}");
            _sseConnected = false;
        }
    }

    [JSInvokable]
    public async Task OnSseEvent(JsonElement eventData)
    {
        Console.WriteLine($"SignalR event received: {eventData}");

        // Parse event type
        if (eventData.TryGetProperty("eventType", out var eventType))
        {
            var eventTypeName = eventType.GetString();

            // Reload cart for all cart-related events
            if (eventTypeName == "cart-updated")
            {
                await LoadCart();
                StateHasChanged();
            }
        }
    }

    private async Task RemoveItem(string sku)
    {
        if (!_cartId.HasValue) return;

        _isProcessing = true;
        try
        {
            var client = HttpClientFactory.CreateClient("StorefrontApi");
            var response = await client.DeleteAsync($"/api/storefront/carts/{_cartId.Value}/items/{sku}");

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Item removed from cart", Severity.Success);
                // Reload cart immediately (SignalR will also trigger reload, but this ensures it happens)
                await LoadCart();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add($"Failed to remove item: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error removing item: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task IncreaseQuantity(string sku, int currentQuantity)
    {
        await ChangeQuantity(sku, currentQuantity + 1);
    }

    private async Task DecreaseQuantity(string sku, int currentQuantity)
    {
        if (currentQuantity > 1)
        {
            await ChangeQuantity(sku, currentQuantity - 1);
        }
    }

    private async Task ChangeQuantity(string sku, int newQuantity)
    {
        if (!_cartId.HasValue) return;

        _isProcessing = true;
        try
        {
            var client = HttpClientFactory.CreateClient("StorefrontApi");
            var response = await client.PutAsJsonAsync(
                $"/api/storefront/carts/{_cartId.Value}/items/{sku}/quantity",
                new { newQuantity });

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Quantity updated", Severity.Success);
                // Reload cart immediately (SignalR will also trigger reload, but this ensures it happens)
                await LoadCart();
                StateHasChanged();
            }
            else
            {
                Snackbar.Add($"Failed to update quantity: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error updating quantity: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task ProceedToCheckout()
    {
        await JS.InvokeVoidAsync("console.log", $"[Cart] ProceedToCheckout called. _cartId={_cartId}");

        if (!_cartId.HasValue)
        {
            await JS.InvokeVoidAsync("console.log", "[Cart] No cartId - returning early");
            Snackbar.Add("No cart found", Severity.Error);
            return;
        }

        await JS.InvokeVoidAsync("console.log", $"[Cart] Making POST to /api/storefront/carts/{_cartId.Value}/checkout");
        _isProcessing = true;
        try
        {
            var client = HttpClientFactory.CreateClient("StorefrontApi");
            var response = await client.PostAsync($"/api/storefront/carts/{_cartId.Value}/checkout", null);

            await JS.InvokeVoidAsync("console.log", $"[Cart] POST response status: {response.StatusCode}");

            if (response.IsSuccessStatusCode)
            {
                // Parse checkoutId from response
                var result = await response.Content.ReadFromJsonAsync<InitiateCheckoutResponse>();

                await JS.InvokeVoidAsync("console.log", $"[Cart] Parsed checkoutId: {result?.CheckoutId}");

                if (result?.CheckoutId != null)
                {
                    // Store checkoutId in localStorage
                    await JS.InvokeVoidAsync("authHelper.setCheckoutId", result.CheckoutId.ToString());

                    // Navigate to checkout page
                    Navigation.NavigateTo("/checkout");
                }
                else
                {
                    await JS.InvokeVoidAsync("console.log", "[Cart] No checkoutId in response");
                    Snackbar.Add("Failed to initiate checkout (no checkout ID returned)", Severity.Error);
                }
            }
            else
            {
                var errorBody = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("console.log", $"[Cart] POST failed with status {response.StatusCode}, body: {errorBody}");
                Snackbar.Add($"Failed to initiate checkout: {response.StatusCode}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("console.log", $"[Cart] Exception: {ex}");
            Snackbar.Add($"Error initiating checkout: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("signalrClient.unsubscribe");
            _dotNetHelper?.Dispose();
        }
        catch
        {
            // Ignore disposal errors
        }
    }

    // View models matching BFF CartView
    private sealed record CartView(
        Guid CartId,
        Guid CustomerId,
        IReadOnlyList<CartLineItemView> Items,
        decimal Subtotal);

    private sealed record CartLineItemView(
        string Sku,
        string ProductName,
        string ProductImageUrl,
        int Quantity,
        decimal UnitPrice,
        decimal LineTotal);

    private sealed record InitiateCheckoutResponse(Guid? CheckoutId);
}

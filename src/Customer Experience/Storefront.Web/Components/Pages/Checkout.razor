@page "/checkout"
@attribute [Authorize]
@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Checkout - CritterSupply</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Checkout</MudText>

@if (_isLoading)
{
    <MudProgressCircular Indeterminate="true" data-testid="checkout-loading" />
}
else if (_checkoutView == null)
{
    <MudAlert Severity="Severity.Error" data-testid="checkout-error">Unable to load checkout. Please try again.</MudAlert>
}
else
{
    <MudGrid>
        <!-- Left column: 4-step checkout wizard -->
        <MudItem xs="12" md="8">
            <MudStepper @ref="_stepper" Linear="true" data-testid="checkout-stepper">
                <!-- Step 1: Shipping Address -->
                <MudStep Title="Shipping Address">
                    <ChildContent>
                        <MudText Typo="Typo.h6" Class="mb-4" data-testid="checkout-step-title">Select Shipping Address</MudText>

                        @if (_checkoutView.SavedAddresses.Any())
                        {
                            <MudSelect T="Guid" Label="Saved Addresses" Variant="Variant.Outlined" @bind-Value="_selectedAddressId" Disabled="@_isProcessing" data-testid="address-select">
                                @foreach (var address in _checkoutView.SavedAddresses)
                                {
                                    <MudSelectItem T="Guid" Value="@address.AddressId" data-testid="@($"address-option-{address.Nickname.ToLowerInvariant()}")">@address.Nickname - @address.DisplayLine</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" data-testid="no-saved-addresses">No saved addresses. Add an address to continue.</MudAlert>
                        }

                        @if (_isProcessing)
                        {
                            <MudProgressLinear Indeterminate="true" Class="mt-4" data-testid="checkout-processing" />
                        }

                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SaveShippingAddressAndContinue" Disabled="@_isProcessing" Class="mt-4" data-testid="btn-save-address">
                            Save & Continue
                        </MudButton>
                    </ChildContent>
                </MudStep>

                <!-- Step 2: Shipping Method -->
                <MudStep Title="Shipping Method">
                    <ChildContent>
                        <MudText Typo="Typo.h6" Class="mb-4" data-testid="checkout-step-title">Select Shipping Method</MudText>

                        <MudRadioGroup @bind-Value="_selectedShippingMethod" Disabled="@_isProcessing" data-testid="shipping-method-group">
                            <MudRadio Value="@("Standard")" data-testid="shipping-method-standard">Standard Ground (5–7 days) — $5.99</MudRadio>
                            <MudRadio Value="@("Express")" data-testid="shipping-method-express">Express Shipping (2–3 days) — $12.99</MudRadio>
                            <MudRadio Value="@("NextDay")" data-testid="shipping-method-nextday">Next Day Air (1 day) — $24.99</MudRadio>
                        </MudRadioGroup>

                        @if (_isProcessing)
                        {
                            <MudProgressLinear Indeterminate="true" Class="mt-4" data-testid="checkout-processing" />
                        }

                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SaveShippingMethodAndContinue" Disabled="@_isProcessing" Class="mt-4" data-testid="btn-save-shipping-method">
                            Save & Continue
                        </MudButton>
                    </ChildContent>
                </MudStep>

                <!-- Step 3: Payment -->
                <MudStep Title="Payment">
                    <ChildContent>
                        <MudText Typo="Typo.h6" Class="mb-4" data-testid="checkout-step-title">Provide Payment Method</MudText>

                        <MudTextField @bind-Value="_paymentToken" Label="Payment Method" Variant="Variant.Outlined" Placeholder="Enter your card details" Disabled="@_isProcessing" data-testid="payment-token-input" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                            Your payment information is handled securely.
                        </MudText>

                        @if (_isProcessing)
                        {
                            <MudProgressLinear Indeterminate="true" Class="mt-4" data-testid="checkout-processing" />
                        }

                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="@SavePaymentMethodAndContinue" Disabled="@_isProcessing" Class="mt-4" data-testid="btn-save-payment">
                            Save & Continue
                        </MudButton>
                    </ChildContent>
                </MudStep>

                <!-- Step 4: Review & Submit -->
                <MudStep Title="Review & Submit">
                    <MudText Typo="Typo.h6" Class="mb-4" data-testid="checkout-step-title">Order Summary</MudText>

                    <MudPaper Class="pa-4 mb-4">
                        <MudText Typo="Typo.h6" Class="mb-2">Line Items</MudText>
                        @foreach (var item in _checkoutView.Items)
                        {
                            <div class="d-flex justify-space-between mb-2" data-testid="@($"line-item-{item.Sku}")">
                                <MudText>@item.ProductName (x@item.Quantity)</MudText>
                                <MudText data-testid="@($"line-item-total-{item.Sku}")">@item.LineTotal.ToString("C")</MudText>
                            </div>
                        }
                    </MudPaper>

                    <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="@PlaceOrder" Disabled="@_isProcessing" Class="mt-4" data-testid="btn-place-order">
                        Place Order
                    </MudButton>
                </MudStep>
            </MudStepper>
        </MudItem>

        <!-- Right column: always-visible order summary sidebar -->
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-4" Elevation="2">
                <MudText Typo="Typo.h6" Class="mb-3">Order Summary</MudText>

                @foreach (var item in _checkoutView.Items)
                {
                    <div class="d-flex justify-space-between mb-1">
                        <MudText Typo="Typo.body2">@item.ProductName × @item.Quantity</MudText>
                        <MudText Typo="Typo.body2">@item.LineTotal.ToString("C")</MudText>
                    </div>
                }

                <MudDivider Class="my-3" />

                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body1">Subtotal</MudText>
                    <MudText Typo="Typo.body1" data-testid="order-subtotal">@_checkoutView.Subtotal.ToString("C")</MudText>
                </div>
                <div class="d-flex justify-space-between mb-2">
                    <MudText Typo="Typo.body1">Shipping</MudText>
                    <MudText Typo="Typo.body1" data-testid="order-shipping-cost">@CurrentShippingCost.ToString("C")</MudText>
                </div>

                <MudDivider Class="my-3" />

                <div class="d-flex justify-space-between">
                    <MudText Typo="Typo.h6">Total</MudText>
                    <MudText Typo="Typo.h6" data-testid="order-total">@(_checkoutView.Subtotal + CurrentShippingCost).ToString("C")</MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private MudStepper? _stepper;
    private CheckoutView? _checkoutView;
    private bool _isLoading = true;
    private bool _isProcessing = false;
    private Guid _customerId;
    private Guid? _checkoutId;

    private Guid _selectedAddressId;
    private string _selectedShippingMethod = "Standard";
    private string _paymentToken = "";

    /// <summary>
    /// Computes the current shipping cost from the selected shipping method.
    /// Updates the order summary sidebar reactively as the user selects a method.
    /// </summary>
    private decimal CurrentShippingCost => _selectedShippingMethod switch
    {
        "Standard" => 5.99m,
        "Express" => 12.99m,
        "NextDay" => 24.99m,
        _ => 5.99m
    };

    protected override async Task OnInitializedAsync()
    {
        // Get authenticated customer ID
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var customerIdClaim = authState.User.FindFirst("CustomerId")?.Value;
        Console.WriteLine($"[Checkout] OnInitializedAsync: customerIdClaim='{customerIdClaim}', isAuthenticated={authState.User.Identity?.IsAuthenticated}");
        if (!Guid.TryParse(customerIdClaim, out _customerId))
        {
            Console.WriteLine("[Checkout] CustomerId parse failed - returning early");
            // Should not happen due to [Authorize] but handle gracefully
            return;
        }

        // Get checkoutId from localStorage (stored when user clicked "Proceed to Checkout")
        var checkoutIdString = await JS.InvokeAsync<string?>("authHelper.getCheckoutId");
        Console.WriteLine($"[Checkout] checkoutIdString from localStorage='{checkoutIdString}'");
        if (!string.IsNullOrEmpty(checkoutIdString) && Guid.TryParse(checkoutIdString, out var checkoutId))
        {
            _checkoutId = checkoutId;
            await LoadCheckout();
        }
        else
        {
            Console.WriteLine("[Checkout] No checkoutId in localStorage - redirecting to cart");
            // No checkoutId - redirect back to cart
            Snackbar.Add("No active checkout found. Please start checkout from your cart.", Severity.Warning);
            Navigation.NavigateTo("/cart");
        }
    }

    private async Task LoadCheckout()
    {
        _isLoading = true;
        try
        {
            if (!_checkoutId.HasValue) return;

            var client = HttpClientFactory.CreateClient("StorefrontApi");

            // Retry logic to handle async message processing delay
            const int maxRetries = 3;
            const int delayMs = 500;

            for (int attempt = 1; attempt <= maxRetries; attempt++)
            {
                try
                {
                    _checkoutView = await client.GetFromJsonAsync<CheckoutView>($"/api/storefront/checkouts/{_checkoutId.Value}");

                    // Auto-select first saved address for better UX.
                    // If the customer has saved addresses and hasn't already selected one,
                    // pre-select the first address (typically the default/most recent).
                    // User can still change selection via the dropdown.
                    if (_checkoutView?.SavedAddresses.Any() == true && _selectedAddressId == Guid.Empty)
                    {
                        _selectedAddressId = _checkoutView.SavedAddresses.First().AddressId;
                    }

                    return;
                }
                catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound && attempt < maxRetries)
                {
                    await Task.Delay(delayMs);
                }
            }

            Snackbar.Add("Checkout not found. Please start checkout from your cart.", Severity.Error);
            await JS.InvokeVoidAsync("authHelper.clearCheckoutId");
            Navigation.NavigateTo("/cart");
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            Snackbar.Add("Checkout not found. Please start checkout from your cart.", Severity.Error);
            await JS.InvokeVoidAsync("authHelper.clearCheckoutId");
            Navigation.NavigateTo("/cart");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Failed to load checkout: {ex.Message}");
            Snackbar.Add("Failed to load checkout. Please try again.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ─────────────────────────────────────────────────────────────────────
    // Step continuation handlers: save step data then auto-advance stepper.
    // The try/catch ensures the stepper only advances on success, and the
    // exception is swallowed at this level because the inner save methods
    // already show Snackbar error messages and update _isProcessing.
    // Swallowing here keeps the Blazor circuit healthy and allows re-render.
    // ─────────────────────────────────────────────────────────────────────

    private async Task SaveShippingAddressAndContinue()
    {
        try
        {
            await SaveShippingAddress();
            await _stepper!.NextStepAsync();
        }
        catch (Exception)
        {
            // Save method owns error display; swallow here to prevent Blazor circuit disruption
        }
    }

    private async Task SaveShippingMethodAndContinue()
    {
        try
        {
            await SaveShippingMethod();
            await _stepper!.NextStepAsync();
        }
        catch (Exception)
        {
            // Save method owns error display; swallow here to prevent Blazor circuit disruption
        }
    }

    private async Task SavePaymentMethodAndContinue()
    {
        try
        {
            await SavePaymentMethod();
            await _stepper!.NextStepAsync();
        }
        catch (Exception)
        {
            // Save method owns error display; swallow here to prevent Blazor circuit disruption
        }
    }

    // ─────────────────────────────────────────────────────────────────────
    // Step save methods: call BFF endpoints (all routed through StorefrontApi).
    // Each method throws on failure so the continuation handler knows not to advance.
    // ─────────────────────────────────────────────────────────────────────

    private async Task SaveShippingAddress()
    {
        if (_selectedAddressId == Guid.Empty)
        {
            Snackbar.Add("Please select a shipping address to continue", Severity.Warning);
            throw new InvalidOperationException("No address selected");
        }

        // Resolve full address details from the selected address ID
        var selected = _checkoutView!.SavedAddresses.FirstOrDefault(a => a.AddressId == _selectedAddressId);
        if (selected == null)
        {
            Snackbar.Add("Selected address not found. Please try again.", Severity.Error);
            throw new InvalidOperationException("Address not found");
        }

        _isProcessing = true;
        try
        {
            var client = HttpClientFactory.CreateClient("StorefrontApi");
            var payload = new
            {
                addressLine1 = selected.AddressLine1,
                addressLine2 = (string?)null,
                city = selected.City,
                stateOrProvince = selected.StateOrProvince,
                postalCode = selected.PostalCode,
                country = selected.Country
            };
            var response = await client.PostAsJsonAsync($"/api/storefront/checkouts/{_checkoutId!.Value}/shipping-address", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Shipping address saved successfully", Severity.Success);
            }
            else
            {
                var errorMessage = await TryParseErrorMessage(response);
                Snackbar.Add($"Failed to save shipping address: {errorMessage}", Severity.Error);
                throw new HttpRequestException($"Status: {response.StatusCode}");
            }
        }
        catch (HttpRequestException)
        {
            throw;
        }
        catch (Exception ex) when (ex is not InvalidOperationException)
        {
            Console.WriteLine($"Error saving shipping address: {ex.Message}");
            Snackbar.Add("Network error. Please check your connection and try again.", Severity.Error);
            throw;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task SaveShippingMethod()
    {
        if (string.IsNullOrEmpty(_selectedShippingMethod))
        {
            Snackbar.Add("Please select a shipping method to continue", Severity.Warning);
            throw new InvalidOperationException("No shipping method selected");
        }

        _isProcessing = true;
        try
        {
            var client = HttpClientFactory.CreateClient("StorefrontApi");
            var payload = new { shippingMethod = _selectedShippingMethod, shippingCost = CurrentShippingCost };
            var response = await client.PostAsJsonAsync($"/api/storefront/checkouts/{_checkoutId!.Value}/shipping-method", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Shipping method saved successfully", Severity.Success);
            }
            else
            {
                var errorMessage = await TryParseErrorMessage(response);
                Snackbar.Add($"Failed to save shipping method: {errorMessage}", Severity.Error);
                throw new HttpRequestException($"Status: {response.StatusCode}");
            }
        }
        catch (HttpRequestException)
        {
            throw;
        }
        catch (Exception ex) when (ex is not InvalidOperationException)
        {
            Console.WriteLine($"Error saving shipping method: {ex.Message}");
            Snackbar.Add("Network error. Please check your connection and try again.", Severity.Error);
            throw;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task SavePaymentMethod()
    {
        if (string.IsNullOrWhiteSpace(_paymentToken))
        {
            Snackbar.Add("Please enter your payment details to continue", Severity.Warning);
            throw new InvalidOperationException("No payment method entered");
        }

        _isProcessing = true;
        try
        {
            var client = HttpClientFactory.CreateClient("StorefrontApi");
            var payload = new { paymentMethodToken = _paymentToken };
            var response = await client.PostAsJsonAsync($"/api/storefront/checkouts/{_checkoutId!.Value}/payment-method", payload);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Payment method saved successfully", Severity.Success);
            }
            else
            {
                var errorMessage = await TryParseErrorMessage(response);
                Snackbar.Add($"Failed to save payment method: {errorMessage}", Severity.Error);
                throw new HttpRequestException($"Status: {response.StatusCode}");
            }
        }
        catch (HttpRequestException)
        {
            throw;
        }
        catch (Exception ex) when (ex is not InvalidOperationException)
        {
            Console.WriteLine($"Error saving payment method: {ex.Message}");
            Snackbar.Add("Network error. Please check your connection and try again.", Severity.Error);
            throw;
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private async Task<string> TryParseErrorMessage(HttpResponseMessage response)
    {
        try
        {
            var content = await response.Content.ReadAsStringAsync();
            if (content.Contains("\"detail\""))
            {
                var json = JsonDocument.Parse(content);
                if (json.RootElement.TryGetProperty("detail", out var detail))
                    return detail.GetString() ?? response.ReasonPhrase ?? "Unknown error";
            }
            if (content.Contains("\"message\""))
            {
                var json = JsonDocument.Parse(content);
                if (json.RootElement.TryGetProperty("message", out var message))
                    return message.GetString() ?? response.ReasonPhrase ?? "Unknown error";
            }
            return response.ReasonPhrase ?? $"Error {response.StatusCode}";
        }
        catch
        {
            return response.ReasonPhrase ?? $"Error {response.StatusCode}";
        }
    }

    private async Task PlaceOrder()
    {
        if (!_checkoutId.HasValue) return;

        _isProcessing = true;
        try
        {
            var client = HttpClientFactory.CreateClient("StorefrontApi");
            var response = await client.PostAsync($"/api/storefront/checkouts/{_checkoutId.Value}/complete", null);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PlaceOrderResponse>();

                if (result?.OrderId != null)
                {
                    Snackbar.Add("Order placed successfully! Redirecting...", Severity.Success);
                    await JS.InvokeVoidAsync("authHelper.clearCheckoutId");
                    Navigation.NavigateTo($"/order-confirmation/{result.OrderId}");
                }
                else
                {
                    Snackbar.Add("Order placed but confirmation unavailable", Severity.Warning);
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.BadRequest)
            {
                var errorMessage = await TryParseErrorMessage(response);
                Snackbar.Add($"Cannot complete checkout: {errorMessage}", Severity.Error);
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                Snackbar.Add("Checkout not found. Please start checkout from your cart.", Severity.Error);
                await JS.InvokeVoidAsync("authHelper.clearCheckoutId");
                Navigation.NavigateTo("/cart");
            }
            else
            {
                var errorMessage = await TryParseErrorMessage(response);
                Snackbar.Add($"Failed to place order: {errorMessage}", Severity.Error);
            }
        }
        catch (HttpRequestException ex)
        {
            Console.WriteLine($"HTTP error placing order: {ex.Message}");
            Snackbar.Add("Network error. Please check your connection and try again.", Severity.Error);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error placing order: {ex.Message}");
            Snackbar.Add("An unexpected error occurred. Please try again.", Severity.Error);
        }
        finally
        {
            _isProcessing = false;
        }
    }

    private sealed record PlaceOrderResponse(Guid? OrderId);

    // View models matching BFF
    private sealed record CheckoutView(
        Guid CheckoutId,
        Guid CustomerId,
        CheckoutStep CurrentStep,
        IReadOnlyList<CartLineItemView> Items,
        IReadOnlyList<AddressSummary> SavedAddresses,
        decimal Subtotal,
        decimal ShippingCost,
        decimal Total,
        bool CanProceedToNextStep);

    private enum CheckoutStep
    {
        ShippingAddress = 1,
        ShippingMethod = 2,
        Payment = 3,
        Review = 4
    }

    private sealed record AddressSummary(
        Guid AddressId,
        string Nickname,
        string AddressLine1,
        string City,
        string StateOrProvince,
        string PostalCode,
        string Country,
        string DisplayLine);

    private sealed record CartLineItemView(
        string Sku,
        string ProductName,
        string ProductImageUrl,
        int Quantity,
        decimal UnitPrice,
        decimal LineTotal);
}

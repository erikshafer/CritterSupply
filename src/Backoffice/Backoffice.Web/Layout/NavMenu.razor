<MudNavMenu>
    <MudText Typo="Typo.h6" Class="px-4 py-2">Navigation</MudText>

    <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">
        Home
    </MudNavLink>

    <AuthorizeView Policy="CustomerService">
        <MudNavLink Href="/customers/search" Icon="@Icons.Material.Filled.Search">
            Customer Search
        </MudNavLink>
    </AuthorizeView>

    <AuthorizeView Roles="customer-service,operations-manager,system-admin">
        <MudNavLink Href="/orders/search" Icon="@Icons.Material.Filled.ShoppingCart">
            Order Search
        </MudNavLink>
        <MudNavLink Href="/returns" Icon="@Icons.Material.Filled.AssignmentReturn">
            Return Management
        </MudNavLink>
    </AuthorizeView>

    <AuthorizeView Policy="Executive">
        <MudNavLink Href="/dashboard" Icon="@Icons.Material.Filled.Dashboard">
            Executive Dashboard
        </MudNavLink>
    </AuthorizeView>

    <AuthorizeView Policy="OperationsManager">
        <MudNavLink Href="/alerts" Icon="@Icons.Material.Filled.Notifications">
            Operations Alerts
        </MudNavLink>
    </AuthorizeView>

    <AuthorizeView Policy="WarehouseClerk">
        <MudNavLink Href="/inventory" Icon="@Icons.Material.Filled.Warehouse">
            Inventory Management
        </MudNavLink>
    </AuthorizeView>

    <AuthorizeView Policy="PricingManager">
        <MudNavLink Href="/products" Icon="@Icons.Material.Filled.AttachMoney">
            Pricing Admin
        </MudNavLink>
    </AuthorizeView>

    <AuthorizeView Policy="CopyWriter">
        <MudNavLink Href="/products" Icon="@Icons.Material.Filled.Edit">
            Product Catalog
        </MudNavLink>
    </AuthorizeView>

    <AuthorizeView Policy="SystemAdmin">
        <MudNavLink Href="/users" Icon="@Icons.Material.Filled.AdminPanelSettings">
            User Management
        </MudNavLink>
    </AuthorizeView>
</MudNavMenu>

@code {
    // NOTE: Authorization policies checked against AuthorizeView are configured
    // server-side in BackofficeIdentity.Api. The UI uses these same policy names
    // for role-based menu visibility (ADR 0031: Backoffice RBAC Model).
}

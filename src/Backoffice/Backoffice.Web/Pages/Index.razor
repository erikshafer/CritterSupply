@page "/"
@attribute [Authorize]
@inject BackofficeAuthState AuthState

<PageTitle>Dashboard — Backoffice</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Welcome to Backoffice</MudText>

<MudText Typo="Typo.body1" Class="mb-4">
    Hello, @AuthState.FirstName @AuthState.LastName (@AuthState.RoleDisplayName)
</MudText>

<MudPaper Class="pa-4" Elevation="2">
    <MudText Typo="Typo.h6" GutterBottom="true">Quick Links</MudText>

    <MudList T="string">
        <AuthorizeView Policy="CustomerService">
            <MudListItem T="string" Icon="@Icons.Material.Filled.Search" Href="/customers/search">
                Customer Search
            </MudListItem>
        </AuthorizeView>

        <AuthorizeView Policy="Executive">
            <MudListItem T="string" Icon="@Icons.Material.Filled.Dashboard" Href="/dashboard">
                Executive Dashboard
            </MudListItem>
        </AuthorizeView>

        <AuthorizeView Policy="OperationsManager">
            <MudListItem T="string" Icon="@Icons.Material.Filled.Notifications" Href="/alerts">
                Operations Alerts
            </MudListItem>
        </AuthorizeView>

        <AuthorizeView Policy="WarehouseClerk">
            <MudListItem T="string" Icon="@Icons.Material.Filled.Warehouse" Href="/inventory">
                Inventory Management
            </MudListItem>
        </AuthorizeView>

        <AuthorizeView Policy="PricingManager">
            <MudListItem T="string" Icon="@Icons.Material.Filled.AttachMoney" Href="/products">
                Pricing Admin (Manage Prices)
            </MudListItem>
        </AuthorizeView>

        <AuthorizeView Policy="ProductManager">
            <MudListItem T="string" Icon="@Icons.Material.Filled.Inventory" Href="/products">
                Product Admin (Manage Products)
            </MudListItem>
        </AuthorizeView>

        <AuthorizeView Policy="CopyWriter">
            <MudListItem T="string" Icon="@Icons.Material.Filled.Edit" Href="/products">
                Product Catalog (Edit Descriptions)
            </MudListItem>
        </AuthorizeView>

        <AuthorizeView Policy="SystemAdmin">
            <MudListItem T="string" Icon="@Icons.Material.Filled.AdminPanelSettings" Href="/users">
                User Management (Admin Users)
            </MudListItem>
        </AuthorizeView>
    </MudList>
</MudPaper>


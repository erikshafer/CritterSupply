@page "/customers/{CustomerId:guid}"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.SignalR.Client
@using Backoffice.Web.Auth
@using Backoffice.Web.Hub
@attribute [Authorize(Roles = "customer-service,operations-manager,system-admin")]
@inject BackofficeAuthState AuthState
@inject BackofficeHubService HubService
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject ILogger<CustomerDetail> Logger
@inject SessionExpiredService SessionExpiredService

<PageTitle>Customer Detail — Backoffice</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true" data-testid="page-heading">
    Customer Detail
</MudText>

<MudButton Variant="Variant.Text"
           Color="Color.Primary"
           StartIcon="@Icons.Material.Filled.ArrowBack"
           Href="/customers/search"
           Class="mb-4"
           data-testid="back-to-search-btn">
    Back to Customer Search
</MudButton>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       aria-label="Loading customer details"
                       data-testid="customer-loading" />
}

@if (_notFound)
{
    <MudAlert Severity="Severity.Warning" Dense="true" data-testid="customer-not-found">
        Customer not found. The customer ID may be invalid or the customer may have been removed.
    </MudAlert>
}

@if (_customer is not null)
{
    @* Customer info *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Customer ID</MudText>
                <MudText Typo="Typo.body1" data-testid="customer-id">
                    <code>@_customer.CustomerId.ToString("N")[..8]</code>
                </MudText>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Email</MudText>
                <MudText Typo="Typo.body1" data-testid="customer-email">@_customer.Email</MudText>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">First Name</MudText>
                <MudText Typo="Typo.body1" data-testid="customer-first-name">@_customer.FirstName</MudText>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Last Name</MudText>
                <MudText Typo="Typo.body1" data-testid="customer-last-name">@_customer.LastName</MudText>
            </MudItem>
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Member Since</MudText>
                <MudText Typo="Typo.body1" data-testid="customer-created-at">
                    @_customer.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")
                </MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    @* Addresses *@
    @if (_customer.Addresses.Count > 0)
    {
        <MudPaper Elevation="2" Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" GutterBottom="true">Addresses (@_customer.Addresses.Count)</MudText>
            <MudTable Items="_customer.Addresses"
                      Hover="true"
                      Dense="true"
                      Striped="true"
                      Breakpoint="Breakpoint.Sm"
                      aria-label="Customer addresses"
                      data-testid="addresses-table">
                <HeaderContent>
                    <MudTh>Nickname</MudTh>
                    <MudTh>Address</MudTh>
                    <MudTh>City</MudTh>
                    <MudTh>State</MudTh>
                    <MudTh>Postal Code</MudTh>
                    <MudTh>Type</MudTh>
                    <MudTh>Default</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Nickname">@context.Nickname</MudTd>
                    <MudTd DataLabel="Address">
                        @context.AddressLine1
                        @if (!string.IsNullOrEmpty(context.AddressLine2))
                        {
                            <br />@context.AddressLine2
                        }
                    </MudTd>
                    <MudTd DataLabel="City">@context.City</MudTd>
                    <MudTd DataLabel="State">@context.StateOrProvince</MudTd>
                    <MudTd DataLabel="Postal Code">@context.PostalCode</MudTd>
                    <MudTd DataLabel="Type">
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                 Color="@(context.AddressType == "Shipping" ? Color.Primary : Color.Secondary)">
                            @context.AddressType
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Default">
                        @if (context.IsDefault)
                        {
                            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Text">Yes</MudChip>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudPaper>
    }

    @* Order History *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" GutterBottom="true">Order History (@_customer.Orders.Count)</MudText>
        @if (_customer.Orders.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Dense="true" data-testid="no-orders">
                No orders found for this customer.
            </MudAlert>
        }
        else
        {
            <MudTable Items="_customer.Orders"
                      Hover="true"
                      Dense="true"
                      Striped="true"
                      Breakpoint="Breakpoint.Sm"
                      aria-label="Customer order history"
                      data-testid="orders-table">
                <HeaderContent>
                    <MudTh>Order ID</MudTh>
                    <MudTh>Placed At</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Total</MudTh>
                    <MudTh>Actions</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Order ID">
                        <code style="font-size:0.75rem;">@context.OrderId.ToString("N")[..8]</code>
                    </MudTd>
                    <MudTd DataLabel="Placed At">@context.PlacedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(context.Status)"
                                 Variant="Variant.Text">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Total">@context.TotalAmount.ToString("C")</MudTd>
                    <MudTd DataLabel="Actions">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   Href="@($"/orders/{context.OrderId}")"
                                   data-testid="@($"view-order-{context.OrderId}")">
                            View Order
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </MudPaper>
}

@code {
    [Parameter] public Guid CustomerId { get; set; }

    private bool _isLoading = true;
    private bool _notFound;
    private CustomerDetailDto? _customer;

    protected override async Task OnInitializedAsync()
    {
        if (HubService.State != HubConnectionState.Connected)
        {
            await HubService.ConnectAsync();
        }

        await LoadCustomerAsync();
    }

    private async Task LoadCustomerAsync()
    {
        _isLoading = true;
        _notFound = false;

        try
        {
            var client = HttpClientFactory.CreateClient("BackofficeApi");
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthState.AccessToken);

            var response = await client.GetAsync($"/api/backoffice/customers/{CustomerId}");

            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                SessionExpiredService.TriggerSessionExpired();
                return;
            }

            if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
            {
                _notFound = true;
                return;
            }

            if (response.IsSuccessStatusCode)
            {
                _customer = await response.Content.ReadFromJsonAsync<CustomerDetailDto>();
            }
            else
            {
                Snackbar.Add("Failed to load customer details. Please try again.", Severity.Error);
                Logger.LogWarning("Load customer detail failed with status {StatusCode}", response.StatusCode);
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Exception loading customer detail for {CustomerId}", CustomerId);
            Snackbar.Add("Failed to load customer details. Please try again.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Color GetStatusColor(string status) => status.ToLowerInvariant() switch
    {
        "pending" => Color.Warning,
        "confirmed" => Color.Info,
        "shipped" => Color.Primary,
        "delivered" => Color.Success,
        "cancelled" => Color.Error,
        _ => Color.Default
    };

    // Local DTOs (Blazor WASM pattern: cannot reference domain projects directly)
    private sealed record CustomerDetailDto(
        Guid CustomerId,
        string Email,
        string FirstName,
        string LastName,
        DateTime CreatedAt,
        IReadOnlyList<CustomerAddressDto> Addresses,
        IReadOnlyList<OrderSummaryDto> Orders);

    private sealed record CustomerAddressDto(
        Guid AddressId,
        string Nickname,
        string AddressLine1,
        string? AddressLine2,
        string City,
        string StateOrProvince,
        string PostalCode,
        string Country,
        string AddressType,
        bool IsDefault);

    private sealed record OrderSummaryDto(
        Guid OrderId,
        DateTime PlacedAt,
        string Status,
        decimal TotalAmount);
}

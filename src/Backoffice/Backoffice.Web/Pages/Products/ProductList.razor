@page "/products"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "copy-writer,product-manager,system-admin")]
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager Navigation
@inject SessionExpiredService SessionExpiredService

<PageTitle>Products — Backoffice</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" />

<div class="d-flex align-center mb-4">
    <MudText Typo="Typo.h4">Product Catalog</MudText>
    <MudSpacer />
    <MudTextField @bind-Value="_searchText" Placeholder="Search by SKU or name..." Immediate="true"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                  OnKeyUp="FilterProducts" Class="mr-2" Style="max-width: 400px;" />
</div>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
}

<MudTable Items="@_filteredProducts" Hover="true" Striped="true" Dense="true" data-testid="product-table">
    <HeaderContent>
        <MudTh>SKU</MudTh>
        <MudTh>Display Name</MudTh>
        <MudTh>Description</MudTh>
        <MudTh>Status</MudTh>
        <MudTh>Actions</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="SKU">
            <MudText Typo="Typo.body2"><strong>@context.Sku</strong></MudText>
        </MudTd>
        <MudTd DataLabel="Display Name">
            <MudText Typo="Typo.body2">@context.Name</MudText>
        </MudTd>
        <MudTd DataLabel="Description">
            <MudText Typo="Typo.body2">
                @(context.Description.Length > 100 ? context.Description.Substring(0, 100) + "..." : context.Description)
            </MudText>
        </MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Size="Size.Small" Color="@(context.Status == "Active" ? Color.Success : Color.Default)"
                     data-testid="@($"product-status-{context.Sku}")">
                @context.Status
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Actions">
            <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary"
                       Href="@($"/products/{context.Sku}/edit")"
                       data-testid="@($"edit-product-{context.Sku}")">
                Edit
            </MudButton>
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Typo="Typo.body1" Align="Align.Center" Class="pa-4">
            @if (!string.IsNullOrEmpty(_searchText))
            {
                <text>No products match your search.</text>
            }
            else
            {
                <text>No products found in catalog.</text>
            }
        </MudText>
    </NoRecordsContent>
</MudTable>

@if (_productListResult != null && _productListResult.TotalCount > _productListResult.PageSize)
{
    <div class="d-flex justify-center mt-4">
        <MudPagination Count="@_totalPages" Selected="@_currentPage" SelectedChanged="OnPageChanged" />
    </div>
}

@code {
    // Local DTOs (WASM pattern — avoid backend project references)
    private sealed record ProductDto(string Sku, string Name, string Description, string Category, string Status);
    private sealed record ProductListResult(IReadOnlyList<ProductDto> Products, int Page, int PageSize, int TotalCount);

    private List<BreadcrumbItem> _breadcrumbs = new()
    {
        new BreadcrumbItem("Home", href: "/"),
        new BreadcrumbItem("Products", href: null, disabled: true)
    };

    private ProductListResult? _productListResult;
    private List<ProductDto> _allProducts = new();
    private List<ProductDto> _filteredProducts = new();
    private string _searchText = string.Empty;
    private bool _isLoading = true;
    private string? _errorMessage;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private const int PageSize = 25;

    protected override async Task OnInitializedAsync()
    {
        await LoadProductsAsync();
    }

    private async Task LoadProductsAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("BackofficeApi");

            // Call the Backoffice API which will proxy to Product Catalog BC
            var response = await client.GetAsync($"/api/catalog/products?page={_currentPage}&pageSize={PageSize}");

            if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                SessionExpiredService.TriggerSessionExpired();
                return;
            }

            if (!response.IsSuccessStatusCode)
            {
                _errorMessage = "Failed to load products. Please try again.";
                return;
            }

            _productListResult = await response.Content.ReadFromJsonAsync<ProductListResult>();
            if (_productListResult != null)
            {
                _allProducts = _productListResult.Products.ToList();
                _filteredProducts = _allProducts;
                _totalPages = (int)Math.Ceiling((double)_productListResult.TotalCount / PageSize);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Error loading products: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void FilterProducts()
    {
        if (string.IsNullOrWhiteSpace(_searchText))
        {
            _filteredProducts = _allProducts;
        }
        else
        {
            var search = _searchText.ToLowerInvariant();
            _filteredProducts = _allProducts
                .Where(p => p.Sku.ToLowerInvariant().Contains(search) ||
                           p.Name.ToLowerInvariant().Contains(search))
                .ToList();
        }
    }

    private async Task OnPageChanged(int page)
    {
        _currentPage = page;
        await LoadProductsAsync();
    }
}

@page "/team"
@using System.Net.Http.Headers
@attribute [Authorize]
@inject VendorAuthState AuthState
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@inject ILogger<TeamManagement> Logger

<PageTitle>Team Management — Vendor Portal</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <div>
        <MudText Typo="Typo.h4" GutterBottom="false" data-testid="team-page-title">Team Management</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Manage team members and invitations for @AuthState.TenantName.
        </MudText>
    </div>
</div>

@if (!AuthState.CanManageUsers)
{
    <MudAlert Severity="Severity.Warning" data-testid="team-admin-only-message">
        User management is available to Admin users only.
    </MudAlert>
}
else
{
    @* ─── Team Roster ─── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" GutterBottom="true">
            <MudIcon Icon="@Icons.Material.Filled.Group" Class="mr-1" aria-hidden="true" />
            Team Roster
        </MudText>

        @if (_isLoadingRoster)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2"
                               aria-label="Loading team roster"
                               data-testid="roster-loading" />
        }
        else if (_rosterError)
        {
            <MudAlert Severity="Severity.Error" data-testid="roster-error-message">
                Failed to load team roster. Please try again.
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                           OnClick="LoadRosterAsync" Class="ml-2"
                           data-testid="roster-retry-btn">
                    Retry
                </MudButton>
            </MudAlert>
        }
        else if (_rosterMembers.Count == 0)
        {
            <MudAlert Severity="Severity.Info" data-testid="roster-empty-message">
                No team members found.
            </MudAlert>
        }
        else
        {
            <MudTable Items="_rosterMembers" Hover="true" Breakpoint="Breakpoint.Sm"
                      data-testid="team-roster-table" aria-label="Team roster">
                <HeaderContent>
                    <MudTh>Name</MudTh>
                    <MudTh>Email</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Last Login</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Name" data-testid="@($"member-name-{context.UserId}")">
                        @FormatMemberName(context)
                    </MudTd>
                    <MudTd DataLabel="Email" data-testid="@($"member-email-{context.UserId}")">
                        @context.Email
                    </MudTd>
                    <MudTd DataLabel="Role">
                        <MudChip T="string" Size="Size.Small"
                                 Color="GetRoleColor(context.Role)"
                                 Variant="Variant.Outlined"
                                 data-testid="@($"member-role-{context.UserId}")">
                            @FormatRole(context.Role)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small"
                                 Color="GetStatusColor(context.Status)"
                                 Variant="Variant.Filled"
                                 data-testid="@($"member-status-{context.UserId}")">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Last Login" data-testid="@($"member-last-login-{context.UserId}")">
                        @if (context.ActivatedAt.HasValue)
                        {
                            <MudTooltip Text="@context.ActivatedAt.Value.ToLocalTime().ToString("g")">
                                @context.ActivatedAt.Value.ToLocalTime().ToString("MMM d, yyyy")
                            </MudTooltip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">—</MudText>
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2"
                     data-testid="roster-count">
                @_rosterMembers.Count team member@(_rosterMembers.Count != 1 ? "s" : "")
            </MudText>
        }
    </MudPaper>

    @* ─── Pending Invitations ─── *@
    <MudPaper Elevation="2" Class="pa-4 mb-4">
        <MudText Typo="Typo.h6" GutterBottom="true">
            <MudIcon Icon="@Icons.Material.Filled.MailOutline" Class="mr-1" aria-hidden="true" />
            Pending Invitations
        </MudText>

        @if (_isLoadingInvitations)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-2"
                               aria-label="Loading pending invitations"
                               data-testid="invitations-loading" />
        }
        else if (_invitationsError)
        {
            <MudAlert Severity="Severity.Error" data-testid="invitations-error-message">
                Failed to load pending invitations. Please try again.
                <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small"
                           OnClick="LoadInvitationsAsync" Class="ml-2"
                           data-testid="invitations-retry-btn">
                    Retry
                </MudButton>
            </MudAlert>
        }
        else if (_pendingInvitations.Count == 0)
        {
            <MudAlert Severity="Severity.Info" data-testid="invitations-empty-message">
                No pending invitations.
            </MudAlert>
        }
        else
        {
            <MudTable Items="_pendingInvitations" Hover="true" Breakpoint="Breakpoint.Sm"
                      data-testid="pending-invitations-table" aria-label="Pending invitations">
                <HeaderContent>
                    <MudTh>Email</MudTh>
                    <MudTh>Role</MudTh>
                    <MudTh>Status</MudTh>
                    <MudTh>Invited</MudTh>
                    <MudTh>Expires</MudTh>
                    <MudTh>Resends</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Email" data-testid="@($"invitation-email-{context.UserId}")">
                        @context.Email
                    </MudTd>
                    <MudTd DataLabel="Role">
                        <MudChip T="string" Size="Size.Small"
                                 Color="GetRoleColor(context.Role)"
                                 Variant="Variant.Outlined"
                                 data-testid="@($"invitation-role-{context.UserId}")">
                            @FormatRole(context.Role)
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Status">
                        <MudChip T="string" Size="Size.Small"
                                 Color="GetInvitationStatusColor(context.Status)"
                                 Variant="Variant.Filled"
                                 data-testid="@($"invitation-status-{context.UserId}")">
                            @context.Status
                        </MudChip>
                    </MudTd>
                    <MudTd DataLabel="Invited" data-testid="@($"invitation-date-{context.UserId}")">
                        <MudTooltip Text="@context.InvitedAt.ToLocalTime().ToString("g")">
                            @context.InvitedAt.ToLocalTime().ToString("MMM d, yyyy")
                        </MudTooltip>
                    </MudTd>
                    <MudTd DataLabel="Expires" data-testid="@($"invitation-expires-{context.UserId}")">
                        <MudTooltip Text="@context.ExpiresAt.ToLocalTime().ToString("g")">
                            @context.ExpiresAt.ToLocalTime().ToString("MMM d, yyyy")
                        </MudTooltip>
                    </MudTd>
                    <MudTd DataLabel="Resends" data-testid="@($"invitation-resends-{context.UserId}")">
                        @context.ResendCount
                    </MudTd>
                </RowTemplate>
            </MudTable>

            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2"
                     data-testid="invitations-count">
                @_pendingInvitations.Count pending invitation@(_pendingInvitations.Count != 1 ? "s" : "")
            </MudText>
        }
    </MudPaper>
}

@code {
    // Roster state
    private bool _isLoadingRoster = true;
    private bool _rosterError;
    private List<TeamRosterMemberModel> _rosterMembers = [];

    // Invitations state
    private bool _isLoadingInvitations = true;
    private bool _invitationsError;
    private List<PendingInvitationModel> _pendingInvitations = [];

    protected override async Task OnInitializedAsync()
    {
        if (AuthState.CanManageUsers)
        {
            await Task.WhenAll(LoadRosterAsync(), LoadInvitationsAsync());
        }
    }

    // ─── Data Loading ───

    private async Task LoadRosterAsync()
    {
        _isLoadingRoster = true;
        _rosterError = false;
        try
        {
            var client = CreateAuthenticatedClient();
            var response = await client.GetAsync("/api/vendor-portal/team/roster");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<TeamRosterResponse>();
                _rosterMembers = result?.Members?.ToList() ?? [];
            }
            else
            {
                _rosterError = true;
                Snackbar.Add("Failed to load team roster.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _rosterError = true;
            Logger.LogDebug(ex, "Exception loading team roster.");
            Snackbar.Add("Failed to load team roster. Please try again.", Severity.Error);
        }
        finally
        {
            _isLoadingRoster = false;
        }
    }

    private async Task LoadInvitationsAsync()
    {
        _isLoadingInvitations = true;
        _invitationsError = false;
        try
        {
            var client = CreateAuthenticatedClient();
            var response = await client.GetAsync("/api/vendor-portal/team/invitations/pending");

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<PendingInvitationsResponse>();
                _pendingInvitations = result?.Invitations?.ToList() ?? [];
            }
            else
            {
                _invitationsError = true;
                Snackbar.Add("Failed to load pending invitations.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            _invitationsError = true;
            Logger.LogDebug(ex, "Exception loading pending invitations.");
            Snackbar.Add("Failed to load pending invitations. Please try again.", Severity.Error);
        }
        finally
        {
            _isLoadingInvitations = false;
        }
    }

    // ─── Helpers ───

    private HttpClient CreateAuthenticatedClient()
    {
        var client = HttpClientFactory.CreateClient("VendorPortalApi");
        if (!string.IsNullOrEmpty(AuthState.AccessToken))
            client.DefaultRequestHeaders.Authorization =
                new AuthenticationHeaderValue("Bearer", AuthState.AccessToken);
        return client;
    }

    private static string FormatMemberName(TeamRosterMemberModel member)
    {
        if (!string.IsNullOrWhiteSpace(member.FirstName) || !string.IsNullOrWhiteSpace(member.LastName))
            return $"{member.FirstName} {member.LastName}".Trim();
        return member.Email;
    }

    private static string FormatRole(string role) => role switch
    {
        "Admin" => "Admin",
        "CatalogManager" => "Catalog Manager",
        "ReadOnly" => "Read Only",
        _ => role
    };

    private static Color GetRoleColor(string role) => role switch
    {
        "Admin" => Color.Primary,
        "CatalogManager" => Color.Info,
        "ReadOnly" => Color.Default,
        _ => Color.Default
    };

    private static Color GetStatusColor(string status) => status switch
    {
        "Active" => Color.Success,
        "Invited" => Color.Info,
        "Deactivated" => Color.Error,
        _ => Color.Default
    };

    private static Color GetInvitationStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Expired" => Color.Error,
        _ => Color.Default
    };

    // ─── Local DTOs ───

    private sealed record TeamRosterResponse(
        Guid VendorTenantId,
        IReadOnlyList<TeamRosterMemberModel> Members,
        int TotalCount);

    private sealed record TeamRosterMemberModel(
        Guid UserId,
        string Email,
        string FirstName,
        string LastName,
        string Role,
        string Status,
        DateTimeOffset? InvitedAt,
        DateTimeOffset? ActivatedAt,
        DateTimeOffset? DeactivatedAt);

    private sealed record PendingInvitationsResponse(
        Guid VendorTenantId,
        IReadOnlyList<PendingInvitationModel> Invitations,
        int TotalCount);

    private sealed record PendingInvitationModel(
        Guid UserId,
        string Email,
        string Role,
        string Status,
        int ResendCount,
        DateTimeOffset InvitedAt,
        DateTimeOffset ExpiresAt);
}

@page "/change-requests"
@attribute [Authorize]
@inject VendorAuthState AuthState
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject ILogger<ChangeRequests> Logger

<PageTitle>Change Requests — Vendor Portal</PageTitle>

<div class="d-flex align-center justify-space-between mb-4">
    <div>
        <MudText Typo="Typo.h4" GutterBottom="false">Change Requests</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Track product change requests submitted to the Product Catalog team.
        </MudText>
    </div>

    @if (AuthState.CanSubmitChangeRequests)
    {
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/change-requests/submit"
                   data-testid="submit-change-request-btn">
            Submit Change Request
        </MudButton>
    }
</div>

@* Status filter chips *@
<MudPaper Elevation="0" Class="mb-3 d-flex gap-2 flex-wrap" role="group" aria-label="Filter by status">
    <MudChip T="string" Color="@(_statusFilter == null ? Color.Primary : Color.Default)"
             Variant="@(_statusFilter == null ? Variant.Filled : Variant.Outlined)"
             OnClick="@(() => ApplyFilter(null))" Size="Size.Small"
             aria-pressed="@(_statusFilter == null ? "true" : "false")">
        All
    </MudChip>
    @foreach (var status in _availableStatuses)
    {
        <MudChip T="string" Color="@(_statusFilter == status ? Color.Primary : Color.Default)"
                 Variant="@(_statusFilter == status ? Variant.Filled : Variant.Outlined)"
                 OnClick="@(() => ApplyFilter(status))" Size="Size.Small"
                 aria-pressed="@(_statusFilter == status ? "true" : "false")">
            @GetStatusLabel(status)
        </MudChip>
    }
</MudPaper>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" aria-label="Loading change requests" />
}
else if (_items is null or { Count: 0 })
{
    <MudAlert Severity="Severity.Info" data-testid="no-requests-message">
        @if (_statusFilter is not null)
        {
            <span>No <strong>@GetStatusLabel(_statusFilter)</strong> change requests found. </span>
            <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small"
                       OnClick="@(() => ApplyFilter(null))"
                       Style="min-width:auto; text-transform:none; font-size:inherit; padding:0; vertical-align:baseline;">
                Clear filter
            </MudButton>
            <span> to see all requests.</span>
        }
        else
        {
            <span>No change requests found.</span>
            @if (AuthState.CanSubmitChangeRequests)
            {
                <span> <MudLink Href="/change-requests/submit">Submit your first change request.</MudLink></span>
            }
        }
    </MudAlert>
}
else
{
    <MudTable Items="_items" Hover="true" Breakpoint="Breakpoint.Sm"
              data-testid="change-requests-table" aria-label="Change requests">
        <HeaderContent>
            <MudTh>SKU</MudTh>
            <MudTh>Title</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Created</MudTh>
            <MudTh>Actions</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="SKU"><MudText Typo="Typo.body2"><code>@context.Sku</code></MudText></MudTd>
            <MudTd DataLabel="Title">@context.Title</MudTd>
            <MudTd DataLabel="Type">
                <MudChip T="string" Size="Size.Small" Color="GetTypeColor(context.Type)" Variant="Variant.Outlined">
                    @GetTypeLabel(context.Type)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Status">
                <MudChip T="string" Size="Size.Small" Color="GetStatusColor(context.Status)" Variant="Variant.Filled">
                    @GetStatusLabel(context.Status)
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Created">
                <MudTooltip Text="@context.CreatedAt.ToLocalTime().ToString("g")">
                    @context.CreatedAt.ToLocalTime().ToString("MMM d")
                </MudTooltip>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudButton Variant="Variant.Text" Size="Size.Small"
                           Href="@($"/change-requests/{context.Id}")"
                           data-testid="@($"view-request-{context.Id}")">
                    View
                </MudButton>
                @if (context.Status == "Draft" && AuthState.CanSubmitChangeRequests)
                {
                    <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteDraft(context.Id))"
                               Disabled="_deletingDraftId == context.Id"
                               data-testid="@($"delete-draft-{context.Id}")">
                        Delete
                    </MudButton>
                }
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private IReadOnlyList<ChangeRequestSummaryModel>? _items;
    private bool _isLoading = true;
    private string? _statusFilter;
    private Guid? _deletingDraftId;

    private static readonly IReadOnlyList<string> _availableStatuses =
        ["Draft", "Submitted", "NeedsMoreInfo", "Approved", "Rejected", "Withdrawn", "Superseded"];

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task ApplyFilter(string? status)
    {
        _statusFilter = status;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("VendorPortalApi");
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthState.AccessToken);

            var url = _statusFilter is not null
                ? $"/api/vendor-portal/change-requests?status={Uri.EscapeDataString(_statusFilter)}"
                : "/api/vendor-portal/change-requests";

            var response = await client.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ChangeRequestListResponse>();
                _items = result?.Items ?? [];
            }
            else
            {
                Snackbar.Add("Failed to load change requests.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Exception loading change requests list.");
            Snackbar.Add("Failed to load change requests. Please try again.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Draft" => Color.Default,
        "Submitted" => Color.Info,
        "NeedsMoreInfo" => Color.Warning,
        "Approved" => Color.Success,
        "Rejected" => Color.Error,
        "Withdrawn" => Color.Dark,
        "Superseded" => Color.Dark,
        _ => Color.Default
    };

    private static string GetStatusLabel(string status) => status switch
    {
        "NeedsMoreInfo" => "Needs More Info",
        _ => status
    };

    private static string GetTypeLabel(string type) => type switch
    {
        "DataCorrection" => "Data Correction",
        _ => type
    };

    private static Color GetTypeColor(string type) => type switch
    {
        "Description" => Color.Primary,
        "Image" => Color.Secondary,
        "DataCorrection" => Color.Tertiary,
        _ => Color.Default
    };

    private async Task DeleteDraft(Guid draftId)
    {
        var parameters = new DialogParameters<MudMessageBox>
        {
            { x => x.Title, "Delete Draft" },
            { x => x.Message, "Are you sure you want to delete this draft? This action cannot be undone." },
            { x => x.YesText, "Delete" },
            { x => x.CancelText, "Cancel" },
        };

        var dialog = await DialogService.ShowAsync<MudMessageBox>("Delete Draft", parameters);
        var result = await dialog.Result;

        if (result is { Canceled: true })
            return;

        _deletingDraftId = draftId;
        try
        {
            var client = HttpClientFactory.CreateClient("VendorPortalApi");
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthState.AccessToken);

            var response = await client.PostAsync(
                $"/api/vendor-portal/change-requests/{draftId}/withdraw", null);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Draft deleted.", Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add("Failed to delete draft.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "Exception deleting draft {DraftId}.", draftId);
            Snackbar.Add("Failed to delete draft.", Severity.Error);
        }
        finally
        {
            _deletingDraftId = null;
        }
    }

    private sealed record ChangeRequestSummaryModel(
        Guid Id,
        string Sku,
        string Type,
        string Status,
        string Title,
        DateTimeOffset CreatedAt,
        DateTimeOffset? SubmittedAt,
        DateTimeOffset? ResolvedAt);

    private sealed record ChangeRequestListResponse(
        IReadOnlyList<ChangeRequestSummaryModel> Items,
        int TotalCount);
}

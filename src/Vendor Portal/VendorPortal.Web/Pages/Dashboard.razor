@page "/dashboard"
@using System.Net.Http.Json
@using System.Text.Json
@using System.Text.Json.Serialization
@using Microsoft.AspNetCore.SignalR.Client
@using VendorPortal.Web.Auth
@using VendorPortal.Web.Hub
@attribute [Authorize]
@inject VendorAuthState AuthState
@inject VendorHubService HubService
@inject IHttpClientFactory HttpClientFactory
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>Dashboard — Vendor Portal</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">
    Dashboard
</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
    @AuthState.TenantName — @AuthState.RoleDisplayName view
</MudText>

@if (_isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4"
                       aria-label="Loading dashboard data" />
}

@* P1-C: In-page recovery banner when SignalR terminally disconnects *@
@if (HubService.State == HubConnectionState.Disconnected)
{
    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3"
              aria-live="assertive" data-testid="hub-disconnected-banner">
        <MudIcon Icon="@Icons.Material.Filled.WifiOff" Class="mr-1" aria-hidden="true" />
        Live updates are paused.
        <MudButton Variant="Variant.Text" Color="Color.Warning" Size="Size.Small"
                   OnClick="ReconnectAsync" Class="ml-1 pa-0" Style="min-width:auto; text-transform:none;">
            Reconnect
        </MudButton>
        or refresh the page to restore live data.
    </MudAlert>
}

@if (_summary is not null)
{
    <section aria-label="Dashboard summary">
        @* KPI cards ordered urgency-first: Alerts → Requests → Inventory *@
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center"
                          aria-label="@($"Low Stock Alerts: {_activeLowStockAlerts}")">
                    <MudIcon Icon="@Icons.Material.Filled.Warning"
                             Color="@(_activeLowStockAlerts > 0 ? Color.Error : Color.Success)"
                             Style="font-size:2rem;" aria-hidden="true" />
                    @* P1-A: aria-live wrapper so screen readers announce live count changes *@
                    <div aria-live="polite" aria-atomic="true">
                        <MudText Typo="Typo.h4">@_activeLowStockAlerts</MudText>
                    </div>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Low Stock Alerts</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center"
                          aria-label="@($"Pending Change Requests: {_summary.PendingChangeRequests}")">
                    <MudIcon Icon="@Icons.Material.Filled.EditNote"
                             Color="@(_summary.PendingChangeRequests > 0 ? Color.Warning : Color.Success)"
                             Style="font-size:2rem;" aria-hidden="true" />
                    <MudText Typo="Typo.h4">@_summary.PendingChangeRequests</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Pending Change Requests</MudText>
                </MudPaper>
            </MudItem>

            <MudItem xs="12" sm="4">
                <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center"
                          aria-label="@($"Total SKUs: {_summary.TotalSkus}")">
                    <MudIcon Icon="@Icons.Material.Filled.Inventory"
                             Color="Color.Primary"
                             Style="font-size:2rem;" aria-hidden="true" />
                    <MudText Typo="Typo.h4">@_summary.TotalSkus</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Total SKUs</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </section>

    @if (_salesMetricUpdatedAt.HasValue)
    {
        @* aria-live="polite": waits for user to finish current interaction before announcing *@
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3"
                  aria-live="polite" data-testid="sales-metric-updated-banner">
            Sales data updated at @_salesMetricUpdatedAt.Value.ToLocalTime().ToString("HH:mm:ss").
            @* P2-C: Use MudButton (rendered as <button>) for keyboard accessibility — <a> without href is not in tab order *@
            <MudButton Variant="Variant.Text" Color="Color.Info" Size="Size.Small"
                       OnClick="LoadDashboardAsync" Class="ml-1 pa-0"
                       Style="min-width:auto; text-transform:none; font-size:inherit;">
                Refresh
            </MudButton>
        </MudAlert>
    }

    <MudPaper Elevation="2" Class="pa-4 mt-4">
        <MudText Typo="Typo.h6" GutterBottom="true">Quick Actions</MudText>

        @if (AuthState.CanSubmitChangeRequests)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" Class="mr-2">
                Submit Change Request
            </MudButton>
        }

        @if (AuthState.IsAdmin)
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                       StartIcon="@Icons.Material.Filled.Group" Class="mr-2">
                Manage Users
            </MudButton>
        }

        @if (!AuthState.CanSubmitChangeRequests && !AuthState.IsAdmin)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                You can view analytics, manage your notification preferences, and track change request status.
                Contact your Admin to submit change requests.
            </MudText>
        }
    </MudPaper>
}

@code {
    private DashboardSummary? _summary;
    private bool _isLoading = true;

    // Live analytics state — updated by SignalR hub messages
    private int _activeLowStockAlerts;
    private DateTimeOffset? _salesMetricUpdatedAt;

    // Reconnection catch-up: track the timestamp of the last received hub message
    private DateTimeOffset _lastHubMessageAt = DateTimeOffset.MinValue;

    // Hub message listener registration — disposed in Dispose()
    private IDisposable? _hubMessageHandler;

    private static readonly JsonSerializerOptions CloudEventsOptions = new()
    {
        PropertyNameCaseInsensitive = true
    };

    protected override async Task OnInitializedAsync()
    {
        HubService.OnStateChanged += OnHubStateChanged;
        await LoadDashboardAsync();
        RegisterHubListeners();
    }

    /// <summary>
    /// Called whenever the hub connection state changes (connected, reconnecting, disconnected).
    /// On reconnect, fetches missed alerts since the last known hub message.
    /// </summary>
    private async void OnHubStateChanged()
    {
        try
        {
            await InvokeAsync(StateHasChanged);

            if (HubService.State == HubConnectionState.Connected)
            {
                RegisterHubListeners();
                await FetchMissedAlertsAsync();
            }
        }
        catch (Exception)
        {
            // Async void cannot propagate exceptions — swallow here to prevent unobserved task exception.
            // FetchMissedAlertsAsync has its own try-catch; StateHasChanged failures are non-fatal.
        }
    }

    /// <summary>
    /// Attempts to reconnect to the SignalR hub after terminal disconnection.
    /// Called from the in-page disconnect banner (P1-C fix).
    /// </summary>
    private async Task ReconnectAsync()
    {
        await HubService.ConnectAsync();
    }

    /// <summary>
    /// Registers a single handler on the "ReceiveMessage" hub method.
    /// Wolverine wraps all messages in a CloudEvents envelope delivered via this single method.
    /// We demultiplex by the "type" discriminator in the envelope.
    /// Previous registration is disposed before re-registering (safe on reconnect).
    /// </summary>
    private void RegisterHubListeners()
    {
        if (HubService.Connection is null) return;

        _hubMessageHandler?.Dispose();

        _hubMessageHandler = HubService.Connection.On<JsonElement>(
            "ReceiveMessage",
            async envelope =>
            {
                // Wolverine CloudEvents envelope: { "type": "...", "data": { ... } }
                if (!TryGetEventType(envelope, out var eventType)) return;

                if (eventType?.Contains("LowStockAlertRaised") == true)
                {
                    _activeLowStockAlerts++;
                    _lastHubMessageAt = DateTimeOffset.UtcNow;

                    // P2-B: Only show snackbar with SKU when parseable; always provide action
                    var sku = GetSkuFromEnvelope(envelope);
                    var message = sku != "unknown"
                        ? $"Low stock: {sku}"
                        : "New low stock alert received";

                    Snackbar.Add(message, Severity.Warning, config =>
                    {
                        config.Action = "View Alerts";
                        config.ActionColor = Color.Warning;
                        config.OnClick = _ => LoadDashboardAsync();
                    });

                    await InvokeAsync(StateHasChanged);
                }
                else if (eventType?.Contains("SalesMetricUpdated") == true)
                {
                    _salesMetricUpdatedAt = DateTimeOffset.UtcNow;
                    _lastHubMessageAt = DateTimeOffset.UtcNow;
                    await InvokeAsync(StateHasChanged);
                }
                else if (eventType?.Contains("InventoryLevelUpdated") == true)
                {
                    // P1-B: Re-fetch the authoritative alert count from the API.
                    // Inventory level changes may resolve existing alerts on the server side.
                    // The server is the source of truth — we don't try to compute resolution locally.
                    _lastHubMessageAt = DateTimeOffset.UtcNow;
                    await FetchMissedAlertsAsync();
                }
            });
    }

    /// <summary>
    /// Fetches active low-stock alerts from the API.
    /// Called on initial load, after SignalR reconnection, and when InventoryLevelUpdated arrives.
    /// Uses the last-hub-message timestamp as a fence when reconnecting after a gap.
    /// </summary>
    private async Task FetchMissedAlertsAsync()
    {
        try
        {
            var since = _lastHubMessageAt == DateTimeOffset.MinValue
                ? (DateTimeOffset?)null
                : _lastHubMessageAt;

            var client = HttpClientFactory.CreateClient("VendorPortalApi");
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthState.AccessToken);

            var url = since.HasValue
                ? $"/api/vendor-portal/analytics/alerts/low-stock?since={Uri.EscapeDataString(since.Value.ToString("O"))}"
                : "/api/vendor-portal/analytics/alerts/low-stock";

            var response = await client.GetAsync(url);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ActiveLowStockAlertsResponse>();
                if (result is not null)
                {
                    _activeLowStockAlerts = result.TotalCount;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (Exception)
        {
            // Catch-up failure is non-critical — stale count is acceptable; next reconnect fixes it
        }
    }

    private async Task LoadDashboardAsync()
    {
        _isLoading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("VendorPortalApi");
            client.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", AuthState.AccessToken);

            var response = await client.GetAsync("/api/vendor-portal/dashboard");
            if (response.IsSuccessStatusCode)
            {
                _summary = await response.Content.ReadFromJsonAsync<DashboardSummary>();
                if (_summary is not null)
                {
                    _activeLowStockAlerts = _summary.ActiveLowStockAlerts;
                    _salesMetricUpdatedAt = null; // Reset "updated" banner after explicit refresh
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                Snackbar.Add("Session expired. Please log in again.", Severity.Warning);
            }
            else
            {
                Snackbar.Add("Failed to load dashboard.", Severity.Error);
            }
        }
        catch (Exception)
        {
            Snackbar.Add("Failed to load dashboard. Please try again.", Severity.Error);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private static bool TryGetEventType(JsonElement envelope, out string? eventType)
    {
        eventType = null;
        if (envelope.ValueKind != JsonValueKind.Object) return false;
        if (!envelope.TryGetProperty("type", out var typeEl)) return false;
        eventType = typeEl.GetString();
        return eventType is not null;
    }

    private static string GetSkuFromEnvelope(JsonElement envelope)
    {
        try
        {
            if (envelope.TryGetProperty("data", out var data) &&
                data.TryGetProperty("sku", out var sku))
            {
                return sku.GetString() ?? "unknown";
            }
        }
        catch { }
        return "unknown";
    }

    public void Dispose()
    {
        HubService.OnStateChanged -= OnHubStateChanged;
        _hubMessageHandler?.Dispose();
    }

    private sealed record DashboardSummary(
        Guid VendorTenantId,
        string TenantName,
        string UserEmail,
        string UserRole,
        int TotalSkus,
        int PendingChangeRequests,
        int ActiveLowStockAlerts,
        string Message);

    private sealed record ActiveLowStockAlertsResponse(
        IReadOnlyList<LowStockAlertSummary> Alerts,
        int TotalCount,
        DateTimeOffset QueriedAt);

    private sealed record LowStockAlertSummary(
        string Sku,
        string WarehouseId,
        int CurrentQuantity,
        int ThresholdQuantity,
        DateTimeOffset FirstDetectedAt,
        DateTimeOffset LastUpdatedAt);
}

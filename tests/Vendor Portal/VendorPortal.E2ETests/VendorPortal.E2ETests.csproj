<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <ImplicitUsings>enable</ImplicitUsings>
        <IsPackable>false</IsPackable>
        <AssemblyName>VendorPortal.E2ETests</AssemblyName>
        <RootNamespace>VendorPortal.E2ETests</RootNamespace>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="coverlet.collector" />
        <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
        <PackageReference Include="Microsoft.NET.Test.Sdk" />
        <PackageReference Include="Microsoft.Playwright" />
        <PackageReference Include="Reqnroll" />
        <PackageReference Include="Reqnroll.xUnit" />
        <PackageReference Include="Shouldly" />
        <PackageReference Include="Testcontainers.PostgreSql" />
        <PackageReference Include="xunit" />
        <PackageReference Include="xunit.runner.visualstudio" />
    </ItemGroup>

    <ItemGroup>
        <Using Include="Xunit" />
        <Using Include="Shouldly" />
        <Using Include="Reqnroll" />
        <Using Include="Microsoft.Playwright" />
    </ItemGroup>

    <ItemGroup>
        <!-- VendorIdentity.Api (EF Core auth service — real Kestrel server in E2E) -->
        <ProjectReference Include="..\..\..\src\Vendor Identity\VendorIdentity.Api\VendorIdentity.Api.csproj" />
        <!-- VendorPortal.Api (Marten analytics + SignalR hub — real Kestrel server in E2E) -->
        <ProjectReference Include="..\..\..\src\Vendor Portal\VendorPortal.Api\VendorPortal.Api.csproj" />
        <!-- VendorPortal.Web (Blazor WASM — served as static files in E2E) -->
        <ProjectReference Include="..\..\..\src\Vendor Portal\VendorPortal.Web\VendorPortal.Web.csproj" />
    </ItemGroup>

    <!-- xUnit configuration for test execution (disable parallelization for E2E tests) -->
    <ItemGroup>
        <None Update="xunit.runner.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

    <!-- Playwright browser installation target (run once after build).
         Use pwsh on Windows and bash on Unix-like systems so builds are cross-platform
         (macOS/Linux don't necessarily have pwsh installed). Honor PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD. -->
    <Target Name="InstallPlaywrightBrowsers" AfterTargets="Build">
        <!-- Windows: prefer pwsh -> playwright.ps1. Don't fail the build if pwsh is missing (IgnoreExitCode). -->
        <Exec Command="pwsh bin/$(Configuration)/$(TargetFramework)/playwright.ps1 install chromium"
              Condition="'$(OS)' == 'Windows_NT' and '$(PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD)' != '1'"
              IgnoreExitCode="true" />

        <!-- Non-Windows: Try pwsh if present, otherwise fallback to playwright.sh. If neither is possible, print a message but don't fail the build. -->
        <Exec Condition="'$(OS)' != 'Windows_NT' and '$(PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD)' != '1'"
              Command="bash -c 'if command -v pwsh &gt;/dev/null 2&gt;&amp;1; then pwsh bin/$(Configuration)/$(TargetFramework)/playwright.ps1 install chromium; elif [ -x bin/$(Configuration)/$(TargetFramework)/playwright.sh ]; then bash bin/$(Configuration)/$(TargetFramework)/playwright.sh install chromium; else echo &quot;Playwright browser install skipped: no pwsh and no playwright.sh found. Set PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1 to suppress this.&quot;; fi'"
              IgnoreExitCode="true" />
    </Target>

</Project>
